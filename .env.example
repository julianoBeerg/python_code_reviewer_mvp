# Configurações do GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=seu_token_de_acesso_pessoal_aqui
GITLAB_PROJECT_ID=id_do_seu_projeto_aqui

# Configurações do GitHub
# Gere em: https://github.com/settings/tokens (Precisa de acesso a repo)
GITHUB_TOKEN=seu_token_do_github_aqui
GITHUB_REPO=usuario/nome-do-repositorio

# Configurações de LLM (Gemini)
# Obtenha sua chave gratuita em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_gemini_aqui
LLM_MODEL=gemini-1.5-flash

# Configurações do RAG Local
VECTOR_DB_PATH=.index/
